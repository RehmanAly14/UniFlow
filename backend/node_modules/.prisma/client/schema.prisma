// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model User {
  id       String @id
  email    String @unique
  fullName String
  role     Role   @default(STUDENT)

  // Student Specific
  agNumber String? @unique
  degree   String?
  semester Int?
  section  String?

  // Teacher Specific
  teacherId    String?       @unique
  resources    Resource[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Timetable {
  id          String   @id @default(cuid())
  day         String
  room        String
  startTime   String
  endTime     String
  subjectCode String
  degree      String
  semester    Int
  section     String
  teacherName String
  createdAt   DateTime @default(now())
}

model Resource {
  id          String  @id @default(uuid())
  title       String
  description String?

  subjectCode String

  fileUrl      String
  filePublicId String

  degree   String
  semester Int
  section  String

  teacherId String
  teacher   User   @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
}

model ChatMessage {
  id      String @id @default(uuid())
  userId  String
  role    String
  content String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
